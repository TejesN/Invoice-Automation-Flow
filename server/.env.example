# Express port (Railway sets this automatically)
PORT=3001

# SQLite database path
# Local dev: relative to the server/ directory
# Railway: set this in Variables tab as: file:./data/ap.db
DATABASE_URL=file:./data/ap.db

# Anthropic API key for PDF/image invoice extraction
ANTHROPIC_API_KEY=sk-ant-api03-...

# Comma-separated list of allowed frontend origins (add your Vercel URL here)
ALLOWED_ORIGINS=https://your-app.vercel.app
